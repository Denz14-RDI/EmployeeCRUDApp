@model EmployeeCRUDApp.Models.Employee
@{
    ViewData["Title"] = "Add Employee";
}

<div class="page-header" style="margin-top: 40px;">
    <div>
        <div class="page-eyebrow">Human Resources</div>
        <h1 class="page-title">Add Employee</h1>
        <p class="page-subtitle">Fill in the details to register a new employee.</p>
    </div>
    <a asp-action="Index" class="btn btn-secondary">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="15 18 9 12 15 6" />
        </svg>
        Back to List
    </a>
</div>

<div class="form-card" style="margin-top: 20px;">
    <div class="form-card-header">
        <div class="form-card-title">New Employee Registration</div>
        <div class="form-card-sub">All fields are required.</div>
    </div>

    <div class="form-body">
        @using (Html.BeginForm("Create", "Employees", FormMethod.Post))
        {
            @Html.AntiForgeryToken()

            <div class="form-grid">
                <div class="form-group full">
                    <label>Employee ID</label>
                    <input class="field-input disabled" type="text" value="Auto-generated on save" disabled />
                    <span class="field-note">Assigned automatically by the system.</span>
                </div>

                <div class="form-group full">
                    @Html.LabelFor(m => m.Name, new { @class = "form-label" })
                    @Html.TextBoxFor(m => m.Name, new { @class = "field-input", placeholder = "Enter full name" })
                    @Html.ValidationMessageFor(m => m.Name)
                </div>

                <div class="form-group">
                    @Html.LabelFor(m => m.Position, new { @class = "form-label" })
                    @Html.TextBoxFor(m => m.Position, new { @class = "field-input", placeholder = "Enter position" })
                    @Html.ValidationMessageFor(m => m.Position)
                </div>

                <div class="form-group">
                    @Html.LabelFor(m => m.Department, new { @class = "form-label" })
                    @Html.TextBoxFor(m => m.Department, new { @class = "field-input", placeholder = "Enter department" })
                    @Html.ValidationMessageFor(m => m.Department)
                </div>

                <div class="form-group full">
                    @Html.LabelFor(m => m.Salary, new { @class = "form-label" })
                    @Html.TextBoxFor(m => m.Salary, new { @class = "field-input", type = "number", step = "0.01", placeholder = "0.00" })
                    @Html.ValidationMessageFor(m => m.Salary)
                </div>
            </div>

            <div class="form-actions">
                <input type="submit" value="Save Employee" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        }
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}