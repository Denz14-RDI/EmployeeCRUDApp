@model EmployeeCRUDApp.Models.Employee
@{
    ViewData["Title"] = "Delete Employee";
}

<div class="page-header" style="margin-top: 60px;">
    <div>
        <div class="page-eyebrow">Human Resources</div>
        <h1 class="page-title">Delete Employee</h1>
        <p class="page-subtitle">This action cannot be undone. Please review carefully.</p>
    </div>
</div>

<div class="delete-card" style="margin-top: 30px;">
    <div class="delete-card-header" style="background-color:#f8d7da; padding:16px; border-radius:8px;">
        <div style="display:flex; align-items:center; gap:10px;">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="3 6 5 6 21 6" />
                <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" />
                <path d="M10 11v6" />
                <path d="M14 11v6" />
                <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2" />
            </svg>
            <div>
                <div class="delete-card-title" style="font-weight:700;">Delete Employee</div>
                <div class="delete-card-sub" style="font-size:14px;">You are about to permanently remove this record.</div>
            </div>
        </div>
    </div>

    <div class="delete-body" style="margin-top:20px;">
        <div class="delete-warning" style="background-color:#fff3cd; padding:12px; border-radius:6px; font-size:14px;">
            ⚠️ Are you sure you want to delete this employee? This record will be permanently removed and cannot be recovered.
        </div>

        <p style="font-size:13px;color:var(--muted);margin-bottom:14px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;">
            Employee to be deleted:
        </p>

        <div class="delete-preview" style="border:1px solid #ddd; border-radius:6px; padding:12px;">
            <div class="delete-preview-row"><span>Employee ID</span><span class="accent">@Model.EmployeeId</span></div>
            <div class="delete-preview-row"><span>Full Name</span><span>@Model.Name</span></div>
            <div class="delete-preview-row"><span>Position</span><span>@Model.Position</span></div>
            <div class="delete-preview-row"><span>Department</span><span>@Model.Department</span></div>
            <div class="delete-preview-row"><span>Monthly Salary</span><span class="gold">@Model.Salary.ToString("C")</span></div>
        </div>
    </div>

    <div class="delete-actions" style="margin-top:20px;">
        <form asp-action="Delete" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="EmployeeId" />
            <input type="submit" value="Yes, Delete Employee" class="btn btn-danger" />
            <a asp-action="Details" asp-route-id="@Model.EmployeeId" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>