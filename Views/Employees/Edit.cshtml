@model EmployeeCRUDApp.Models.Employee
@{
    ViewData["Title"] = "Edit Employee";
}

<div class="page-header" style="margin-top: 40px;">
    <div>
        <div class="page-eyebrow">Human Resources</div>
        <h1 class="page-title">Edit Employee</h1>
        <p class="page-subtitle">Update the information for this employee record.</p>
    </div>
    <a asp-action="Index" class="btn btn-secondary">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="15 18 9 12 15 6" />
        </svg>
        Back to List
    </a>
</div>

<div class="form-card" style="margin-top: 20px;">
    <div class="form-card-header" style="background:linear-gradient(135deg,#1a3a2a,#2e6b49)">
        <div class="form-card-title">Editing: <span>@Model.Name</span></div>
        <div class="form-card-sub">
            Employee ID: @Model.EmployeeId &middot; Changes take effect immediately on save.
        </div>
    </div>

    <div class="form-body">
        @using (Html.BeginForm("Edit", "Employees", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(m => m.EmployeeId)

            <div class="form-grid">
                <div class="form-group full">
                    @Html.LabelFor(m => m.EmployeeId, "Employee ID", new { @class = "form-label" })
                    @Html.TextBoxFor(m => m.EmployeeId, new { @class = "field-input disabled", disabled = "disabled" })
                </div>

                <div class="form-group full">
                    @Html.LabelFor(m => m.Name, new { @class = "form-label" })
                    @Html.TextBoxFor(m => m.Name, new { @class = "field-input", placeholder = "Full name" })
                    @Html.ValidationMessageFor(m => m.Name)
                </div>

                <div class="form-group">
                    @Html.LabelFor(m => m.Position, new { @class = "form-label" })
                    @Html.TextBoxFor(m => m.Position, new { @class = "field-input", placeholder = "Position" })
                    @Html.ValidationMessageFor(m => m.Position)
                </div>

                <div class="form-group">
                    @Html.LabelFor(m => m.Department, new { @class = "form-label" })
                    @Html.TextBoxFor(m => m.Department, new { @class = "field-input", placeholder = "Department" })
                    @Html.ValidationMessageFor(m => m.Department)
                </div>

                <div class="form-group full">
                    @Html.LabelFor(m => m.Salary, new { @class = "form-label" })
                    @Html.TextBoxFor(m => m.Salary, new { @class = "field-input", type = "number", step = "0.01", placeholder = "0.00" })
                    @Html.ValidationMessageFor(m => m.Salary)
                </div>
            </div>

            <div class="form-actions">
                <input type="submit" value="Save Changes" class="btn btn-gold" />
                <a asp-action="Details" asp-route-id="@Model.EmployeeId" class="btn btn-secondary">Cancel</a>
            </div>
        }
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}